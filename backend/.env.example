# CoralFlow orchestrator config — copy to .env and fill in. Never commit .env.

# E2B
E2B_API_KEY=

# Supabase (auth + encrypted token storage)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# AES-256 key for encrypting per-user source tokens (base64 of 32 random bytes)
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
TOKEN_ENCRYPTION_KEY=

# Agent model (paid OpenRouter model — free tiers stall on multi-step loops)
AGENT_MODEL=openrouter/moonshotai/kimi-k2.6
AGENT_RUN_TIMEOUT_SECONDS=240

# Sandbox
SANDBOX_TEMPLATE=coralflow-base
SANDBOX_TIMEOUT_SECONDS=900
DEFAULT_SLACK_CHANNEL=incidents-alerts
